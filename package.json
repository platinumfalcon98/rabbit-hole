{
  "name": "rabbit-hole",
  "displayName": "Rabbit Hole",
  "description": "Dev time intelligence — automatic tracking, AI agent attribution, activity dashboard",
  "version": "0.2.0",
  "publisher": "rabbit-hole",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/platinumfalcon98/rabbit-hole.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rabbithole",
          "title": "Rabbit Hole",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "rabbithole": [
        {
          "type": "webview",
          "id": "rabbithole.miniView",
          "name": "Today"
        }
      ]
    },
    "commands": [
      {
        "command": "rabbithole.openDashboard",
        "title": "Rabbit Hole: Open Dashboard",
        "icon": "$(clock)"
      },
      {
        "command": "rabbithole.toggleAgentDetection",
        "title": "Rabbit Hole: Toggle Agent Detection"
      }
    ],
    "configuration": {
      "title": "Rabbit Hole",
      "properties": {
        "rabbithole.detectAgents": {
          "type": "boolean",
          "default": true,
          "description": "Detect and log AI agent activity"
        },
        "rabbithole.idleThresholdMinutes": {
          "type": "number",
          "default": 5,
          "description": "Minutes of inactivity before the active timer pauses"
        },
        "rabbithole.sessionExpiryMinutes": {
          "type": "number",
          "default": 60,
          "description": "Minutes of inactivity before a paused session is closed and a new one starts on return"
        },
        "rabbithole.dailyTargetMinutes": {
          "type": "number",
          "description": "Daily active-coding target in minutes. Streak only increments on days where you meet this target. Leave unset to count any activity."
        },
        "rabbithole.agents": {
          "type": "object",
          "default": {},
          "properties": {
            "claudeCode": {
              "type": "boolean",
              "default": true
            },
            "copilot": {
              "type": "boolean",
              "default": true
            },
            "cursor": {
              "type": "boolean",
              "default": true
            },
            "continue": {
              "type": "boolean",
              "default": true
            }
          },
          "description": "Toggle detection per AI agent"
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --sourcemap",
    "build:webview": "esbuild src/webview/main.ts --bundle --outfile=out/webview/main.js --platform=browser --sourcemap && node scripts/copy-assets.js",
    "watch": "node scripts/watch.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/d3": "^7.4.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "d3": "^7.9.0",
    "jspdf": "^4.2.1"
  }
}
